{
  "version": 2,
  "builds": [
    {
      "src": "backend/dist/src/main.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend/node_modules/.prisma/client/**",
          "backend/node_modules/swagger-ui-dist/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/dist/src/main.js"
    }
  ]
}
