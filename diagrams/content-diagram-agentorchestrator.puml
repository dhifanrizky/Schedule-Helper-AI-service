@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()

title Component Diagram - Agent Orchestrator

' --- Definisi Tag Warna untuk Pengelompokan Panah ---
AddRelTag("core_flow", $textColor="#008080", $lineColor="#008080", $legendText="Core Orchestration & State Flow")
AddRelTag("data_services", $textColor="#D2143A", $lineColor="#D2143A", $legendText="Data Services (Databases)")
AddRelTag("external_systems", $textColor="#800080", $lineColor="#800080", $legendText="External System Interactions")
AddRelTag("internal_support", $textColor="#D98719", $lineColor="#D98719", $legendText="Internal Support (Memory & Tools)")

' --- Top Layer ---
Container(api_gateway, "API Gateway", "NestJS", "Routes and validates incoming requests")

' --- Middle Layer: Orchestrator Boundary ---
Container_Boundary(orchestrator, "Agent Orchestrator") {
    Component(pipeline, "Pipeline Runner", "Python", "Coordinates sequential execution of all agents and manages session lifecycle")
    
    Component(session_state, "Session State", "Python, Pydantic", "Shared data object passed across all agents; holds tasks, condition, ranked tasks, and final schedule")
    Component(memory, "Agent Memory", "Python, LangChain", "Manages per-agent conversation history for multi-turn LLM calls")

    Component(agent1, "Agent 1 - Interpreter", "Python, LangChain", "Parses free-form input into structured tasks via ReAct loop")
    Component(agent2, "Agent 2 - Prioritizer", "Python, LangChain", "Scores and ranks tasks based on user condition and semantic context")
    Component(agent3, "Agent 3 - Translator", "Python, LangChain", "Converts top priorities into action steps and draft schedule")

    Component(task_tools, "Task Tools", "Python", "extract_tasks, ask_clarification, update_task, finalize_tasks")
    Component(scoring_tools, "Scoring Tools", "Python", "get_user_history, retrieve_context, calculate_score, finalize_priority")
    Component(schedule_tools, "Schedule Tools", "Python", "get_calendar_slots, generate_steps, draft_schedule, adjust_schedule")
    
    ' Layout hints to align components horizontally
    Lay_R(agent1, agent2)
    Lay_R(agent2, agent3)
    Lay_R(task_tools, scoring_tools)
    Lay_R(scoring_tools, schedule_tools)
}

' --- External Systems & Databases ---
System_Ext(llm_provider, "LLM Provider", "GPT-4o via OpenAI API")

ContainerDb(vector_db, "Vector Database", "ChromaDB", "Stores semantic embeddings")
ContainerDb(postgres, "PostgreSQL", "NeonDB", "Stores session, history, and schedules")
System_Ext(calendar_system, "Google Calendar", "External calendar service")

' Layout hints for databases
Lay_R(vector_db, postgres)
Lay_R(postgres, calendar_system)

' ================= RELATIONSHIPS (WITH COLORS) =================

' --- API Gateway to Pipeline ---
Rel_D(api_gateway, pipeline, "Triggers pipeline", "sync, JSON", $tags="core_flow")

' --- Pipeline Runner ---
Rel_D(pipeline, session_state, "Initializes and passes to agents", "", $tags="core_flow")
Rel_D(pipeline, agent1, "Runs first", "", $tags="core_flow")
Rel_D(pipeline, agent2, "Runs second", "", $tags="core_flow")
Rel_D(pipeline, agent3, "Runs third", "", $tags="core_flow")

' --- Agents to Session State (Upward) ---
Rel_U(agent1, session_state, "Writes structured tasks", "", $tags="core_flow")
Rel_U(agent2, session_state, "Reads tasks, writes ranked tasks", "", $tags="core_flow")
Rel_U(agent3, session_state, "Reads ranked tasks, writes schedule", "", $tags="core_flow")

' --- Agents to Memory (Downward) ---
Rel_D(agent1, memory, "Reads and writes", "", $tags="internal_support")
Rel_D(agent2, memory, "Reads and writes", "", $tags="internal_support")
Rel_D(agent3, memory, "Reads and writes", "", $tags="internal_support")

' --- Agents to Tools (Downward) ---
Rel_D(agent1, task_tools, "Calls", "", $tags="internal_support")
Rel_D(agent2, scoring_tools, "Calls", "", $tags="internal_support")
Rel_D(agent3, schedule_tools, "Calls", "", $tags="internal_support")

' --- Tools to Databases (Downward) ---
Rel_D(task_tools, postgres, "Reads and writes session", "sync, SQL", $tags="data_services")
Rel_D(scoring_tools, postgres, "Reads user history", "sync, SQL", $tags="data_services")
Rel_D(scoring_tools, vector_db, "Retrieves semantic context", "sync", $tags="data_services")
Rel_D(schedule_tools, postgres, "Writes finalized schedule", "sync, SQL", $tags="data_services")

' --- Tools/Agents to External Systems ---
Rel_D(schedule_tools, calendar_system, "Reads slots and writes events", "sync, HTTPS", $tags="external_systems")

' --- Agents to LLM Provider (Rightward) ---
Rel_R(agent1, llm_provider, "Sends prompts", "async, HTTPS", $tags="external_systems")
Rel_R(agent2, llm_provider, "Sends prompts", "async, HTTPS", $tags="external_systems")
Rel_R(agent3, llm_provider, "Sends prompts", "async, HTTPS", $tags="external_systems")

SHOW_LEGEND()
@enduml