// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid()) // Ubah ke UUID agar aman & sinkron dengan user_id di AI
  email     String   @unique
  hash      String
  name      String?
  
  googleAccessToken  String? @db.Text
  googleRefreshToken String? @db.Text
  
  createdAt DateTime @default(now())

  sessions Session[]
  tasks    Task[] // User punya akses langsung ke task-nya

  @@map("users")
}

model Session {
  id     String @id @default(uuid()) // Gunakan UUID, ini akan sama dengan `thread_id` di LangGraph
  userId String

  // Simpan state penting dari Router
  latestIntent String? // "stress", "overload", "manage_task", "schedule"

  // Status conversation (dari LangGraph)
  status String @default("active") // active, waiting_hitl, done

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[] // Ganti nama 'Input' jadi 'Message' biar mencakup input user & balasan AI

  @@map("sessions")
}

model Message {
  id        Int    @id @default(autoincrement())
  sessionId String

  role    String // "user" atau "ai" atau "counselor"
  content String @db.Text

  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// INI YANG PALING PENTING: Menyimpan hasil ekstraksi Router & Prioritizer
model Task {
  id     String @id @default(uuid()) // Samakan dengan task_id dari LangGraph (misal task_001)
  userId String

  // Dari RawTask (Router)
  title       String
  description String  @db.Text
  category    String // "serius", "santai", dll
  rawInput    String? @db.Text
  rawTime     String?

  // Dari TaskBreakdown & ScheduleItem (Prioritizer & Scheduler)
  estimatedMinutes Int?
  priority         Int? // 1, 2, 3...
  deadline         DateTime?
  startTime        DateTime? // Kapan jadwal ini akan dieksekusi
  status           String    @default("pending") // pending, scheduled, completed
  googleEventId    String?   @unique
  googleTaskId     String?   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tasks")
}
